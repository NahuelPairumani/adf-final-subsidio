{
	"name": "df_bronze_sup_boletas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sup_boletas_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(!isNull(boleta_id) && trim(toString(boleta_id)) != '' && !isNull(ci_beneficiaria) && trim(toString(ci_beneficiaria)) != '') ~> filter1",
				"filter1 derive(boleta_id = toInteger(trim(toString(boleta_id))),",
				"          control_id = toInteger(trim(toString(control_id))),",
				"          ci_beneficiaria = upper(regexReplace(trim(toString(ci_beneficiaria)), '[\\\\s-]', '')),",
				"          nro_boleta = upper(trim(toString(nro_boleta))),",
				"          fecha_emision = coalesce(     toDate(toString(fecha_emision), 'yyyy-MM-dd'),     toDate(toString(fecha_emision), 'dd-MM-yyyy'),     toDate(toString(fecha_emision), 'MM/dd/yyyy'),     toDate(toString(fecha_emision), 'dd/MM/yyyy') ),",
				"          estado = initCap(lower(trim(toString(estado))))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as integer,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          boleta_id,",
				"          control_id,",
				"          ci_beneficiaria,",
				"          nro_boleta,",
				"          fecha_emision,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}