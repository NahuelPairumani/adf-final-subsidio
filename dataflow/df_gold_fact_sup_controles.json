{
	"name": "df_gold_fact_sup_controles",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_sup_controles",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_sup_controles",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(fecha_key = toInteger(toString(fecha_control, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          control_id,",
				"          ci = ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          fecha_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          ci as string,",
				"          establecimiento_id as integer,",
				"          fecha_key as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_id,",
				"          ci,",
				"          establecimiento_id,",
				"          fecha_key,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial",
				"     )) ~> sink1"
			]
		}
	}
}