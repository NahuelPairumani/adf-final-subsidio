{
	"name": "df_gold_fact_sup_controles",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_sup_controles",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_fact_sup_controles",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "exists1"
				},
				{
					"name": "exists2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          anio as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          dia as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source1 derive(fecha_key = year(fecha_control) * 10000 + month(fecha_control) * 100 + dayOfMonth(fecha_control)) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          control_id,",
				"          ci = ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          fecha_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1, source2 exists(select1@ci == source2@ci,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"exists1, source3 exists(select1@fecha_key == source3@fecha_key,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists2",
				"exists2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          ci as string,",
				"          establecimiento_id as integer,",
				"          fecha_key as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_id,",
				"          ci,",
				"          establecimiento_id,",
				"          fecha_key,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial",
				"     )) ~> sink1"
			]
		}
	}
}