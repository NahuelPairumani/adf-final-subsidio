{
	"name": "df_bronze_sup_catalogo_paquetes",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sup_catalogo_paquetes_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(paquete_id = toInteger(trim(toString(paquete_id))),",
				"          nombre = regexReplace(trim(toString(nombre)), '\\\\s+', ' '),",
				"          contenido = regexReplace(trim(toString(contenido)), '\\\\s+', ' '),",
				"          peso_estandar_kg = toDecimal(iif(upper(trim(toString(peso_estandar_kg)))=='NULL' || isNull(peso_estandar_kg), '0.0', regexReplace(trim(toString(peso_estandar_kg)),'[^0-9.]','')), 10, 2),",
				"          costo_estimado_bs = toDecimal(iif(upper(trim(toString(costo_estimado_bs)))=='NULL' || isNull(costo_estimado_bs), '0.0', regexReplace(trim(toString(costo_estimado_bs)),'[^0-9.]','')), 10, 2)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sink1"
			]
		}
	}
}